# --- Telegram ---
# BotFather'dan aldığın token (zorunlu)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Opsiyonel: bot kapalıyken bile sistem mesajlarının gideceği varsayılan chat id.
# Boş bırakılabilir; rotalar zaten kendi chat_id'lerini taşır.
DEFAULT_CHAT_ID=

# --- Tarama ---
# Tüm aktif rotaların kaç dakikada bir taranacağı (varsayılan 10 dk)
CHECK_INTERVAL_MIN=10

# İstekler arası rastgele bekleme (saniye) - anti-ban jitter
REQUEST_JITTER_MIN=4
REQUEST_JITTER_MAX=12

# --- Tarayıcı (Playwright) ---
# true = arka planda görünmez. Hata ayıklarken false yapabilirsin.
HEADLESS=true

# Opsiyonel proxy. Örn: http://user:pass@host:port  (boş = proxy yok)
PROXY=

# --- Depolama ---
DB_PATH=tracker.db

# --- Gelişmiş / Analitik ---
# Fiyat bir önceki ölçüme göre bu yüzde kadar düşünce, hedefin ÜSTÜNDE olsa bile uyar.
# 0 = kapalı. Örn: 15 → %15 ve üzeri ani düşüşlerde haber ver.
DROP_ALERT_PCT=0

# Tek bir rota için kazıma başarısız olursa kaç kez tekrar denensin (üstel backoff)
SCRAPER_MAX_RETRIES=2

# Fiyat bulunamazsa debug/ klasörüne ekran görüntüsü + HTML dök (selector onarımı için)
DEBUG_DUMP=false

# Tarayıcının canlı olup olmadığını kaç dakikada bir kontrol et (çökerse yeniden başlatılır)
HEALTH_CHECK_MIN=10
